---
import BaseLayout from "../../layouts/BaseLayout.astro";

const tools = [
  {
    title: "模板生成器（v1）",
    desc: "项目简报、报价说明、需求变更、催款邮件、周复盘 —— 生成可复制的 Markdown。",
    href: "/tools/templates"
  }
];
---

<BaseLayout
  title="工具｜OPC Helper"
  description="OPC Helper 工具箱：在浏览器里生成可直接复制的业务文档模板。"
>
  <section class="py-6 sm:py-10">
    <h1 class="text-3xl font-semibold tracking-tight text-white">工具箱</h1>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-200/80 sm:text-base">
      面向一人公司的高频文档工具。v1 版本全部在本地生成内容，不需要登录，也不会上传你的信息。
    </p>

    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      {
        tools.map((t) => (
          <a
            href={t.href}
            class="rounded-3xl bg-white/5 p-6 ring-1 ring-white/10 transition hover:bg-white/10"
          >
            <h2 class="text-lg font-semibold text-white">{t.title}</h2>
            <p class="mt-2 text-sm text-slate-200/75">{t.desc}</p>
            <p class="mt-4 text-sm text-indigo-200/80">打开 →</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
