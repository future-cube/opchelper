---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

type Props = {
  title: string;
  description?: string;
};

const { title, description } = Astro.props as Props;
const metaDescription =
  description ??
  "OPC Helper：一人公司的经营助手。提供 SOP、模板、清单与工具，帮你更稳地获客、交付与回款。";
---

<!doctype html>
<html lang="zh-CN" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={metaDescription} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
  </head>
  <body class="min-h-full bg-slate-950 text-slate-100 antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-slate-800 focus:px-3 focus:py-2 focus:text-sm focus:text-slate-100"
    >
      跳到正文
    </a>

    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div
        class="absolute -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-indigo-500/20 blur-3xl"
      >
      </div>
      <div
        class="absolute -bottom-48 right-1/3 h-[520px] w-[520px] rounded-full bg-cyan-400/10 blur-3xl"
      >
      </div>
    </div>

    <Nav />
    <main id="main" class="mx-auto w-full max-w-6xl px-4 pb-16 pt-10 sm:px-6">
      <slot />
    </main>
    <Footer />
  </body>
</html>
